# VIBENICITY BUILD ENGINE - API CONFIGURATION
# Copy this file to .env and fill in your API keys

# ========================================
# REQUIRED API KEYS
# ========================================

# Genius API (for lyrics scraping)
# Get your key: https://genius.com/api-clients
GENIUS_API_KEY=your_genius_api_key_here

# OpenAI API (for slang detection)
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API (for definition research)
# Your existing key
GEMINI_API_KEY=AIzaSyB9jQaRGkfj4Tyq5y5j45RiYAeb_H2e-2g

# ========================================
# OPTIONAL API KEYS
# ========================================

# Spotify API (for trending metadata)
# Get your key: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ========================================
# BUILD ENGINE SETTINGS
# ========================================

# Scanning Configuration
SCAN_FREQUENCY=daily
SONGS_PER_SCAN=50
MAX_TERMS_PER_SCAN=20

# Validation Thresholds
MIN_CONFIDENCE_SCORE=60
AUTO_APPROVE_THRESHOLD=90

# File Paths
VOCABULARY_DATABASE_PATH=../js/cultural-vocabulary-master.js
PENDING_TERMS_PATH=./data/pending_terms.json
PROCESSED_TERMS_PATH=./data/processed_terms.json

# Environment
NODE_ENV=development
PORT=3000
